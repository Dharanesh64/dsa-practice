#include <bits/stdc++.h>
using namespace std;

bool isSafe(int x, int y, vector<vector<int>> &m, int n, vector<vector<int>> &vis){
    
    if(x>=0 && y>=0 && x<n && y<n && m[x][y]==1 && vis[x][y]==0)
        return true;
        
    return false;
}

void solve(int x, int y, vector<vector<int>> &m, int n,
           vector<string> &ans, string path,
           vector<vector<int>> &vis){
    
    if(x==n-1 && y==n-1){
        ans.push_back(path);
        return;
    }
    
    vis[x][y]=1;
    
    // Down
    if(isSafe(x+1,y,m,n,vis))
        solve(x+1,y,m,n,ans,path+'D',vis);
        
    // Left
    if(isSafe(x,y-1,m,n,vis))
        solve(x,y-1,m,n,ans,path+'L',vis);
        
    // Right
    if(isSafe(x,y+1,m,n,vis))
        solve(x,y+1,m,n,ans,path+'R',vis);
        
    // Up
    if(isSafe(x-1,y,m,n,vis))
        solve(x-1,y,m,n,ans,path+'U',vis);
        
    vis[x][y]=0; // backtrack
}


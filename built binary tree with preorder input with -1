#include <iostream>
using namespace std;

struct Node{
    int data;
    Node* left;
    Node* right;

    Node(int val){
        data = val;
        left = right = NULL;
    }
};

Node* build()
{
    int x;
    cin >> x;

    if(x == -1)
        return NULL;

    Node* root = new Node(x);

    root->left = build();
    root->right = build();

    return root;
}

int main()
{
    Node* root = build();
}
